{
  "name": "muse-rents-be",
  "version": "1.0.0",
  "description": "MUSE Rents Backend - Room/Studio Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "kill": "for /f \"tokens=5\" %a in ('netstat -ano ^| findstr :3001') do taskkill /PID %a /F",
    "fresh": "npm run kill & timeout /t 1 & npm run dev"
  },
  "keywords": [
    "muse",
    "rents",
    "room-management"
  ],
  "author": "MUSE Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
